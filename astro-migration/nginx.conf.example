# Nginx configuration for cerrajerosvillaviciosadeodon.madrid
# Place this in /etc/nginx/sites-available/ and symlink to sites-enabled

server {
    listen 80;
    server_name cerrajerosvillaviciosadeodon.madrid www.cerrajerosvillaviciosadeodon.madrid;
    return 301 https://cerrajerosvillaviciosadeodon.madrid$request_uri;
}

server {
    listen 443 ssl http2;
    server_name cerrajerosvillaviciosadeodon.madrid;

    # SSL - Let's Encrypt
    ssl_certificate /etc/letsencrypt/live/cerrajerosvillaviciosadeodon.madrid/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/cerrajerosvillaviciosadeodon.madrid/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    root /var/www/cerrajerosvillaviciosadeodon.madrid;
    index index.html;

    # Redirect www to non-www
    if ($host = www.cerrajerosvillaviciosadeodon.madrid) {
        return 301 https://cerrajerosvillaviciosadeodon.madrid$request_uri;
    }

    # Gzip compression
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript image/svg+xml;

    # Brotli (if module installed)
    # brotli on;
    # brotli_comp_level 6;
    # brotli_types text/plain text/css application/json application/javascript text/xml application/xml text/javascript image/svg+xml;

    # Static asset caching
    location ~* \.(jpg|jpeg|png|gif|ico|svg|webp|avif|woff|woff2|ttf|eot|css|js)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # HTML - short cache for quick updates
    location ~* \.html$ {
        expires 1h;
        add_header Cache-Control "public, must-revalidate";
    }

    # Sitemap and robots.txt
    location = /sitemap-index.xml { }
    location = /robots.txt { }

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;

    # Try files (Astro static site)
    location / {
        try_files $uri $uri/ $uri.html =404;
    }

    # Custom 404
    error_page 404 /404.html;
}
