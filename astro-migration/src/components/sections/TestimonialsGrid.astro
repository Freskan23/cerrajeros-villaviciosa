---
interface Testimonial { id: number; name: string; rating: number; date: string; service: string; location: string; text: string; }
interface Props { testimonials: Testimonial[]; limit?: number; }
const { testimonials, limit = 12 } = Astro.props;
const shown = testimonials.slice(0, limit);
---

<section class="py-16 md:py-24 bg-bg-alt">
  <div class="container">
    <div class="text-center mb-14">
      <span class="inline-block bg-yellow-100 text-yellow-700 text-sm font-bold px-4 py-1.5 rounded-full mb-4">★★★★★ 4.9/5</span>
      <h2 class="text-3xl md:text-4xl font-black text-text mb-4">Lo que dicen nuestros clientes</h2>
      <p class="text-text-muted max-w-xl mx-auto">Más de 95 opiniones verificadas de clientes en Villaviciosa del Odón</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {shown.map(t => (
        <div class="bg-white p-6 rounded-2xl shadow-sm hover:shadow-lg transition-shadow duration-300 border border-gray-100">
          <div class="flex items-center gap-0.5 mb-4">
            {Array.from({ length: t.rating }).map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-text text-sm leading-relaxed mb-5">"{t.text}"</p>
          <div class="flex items-center justify-between pt-4 border-t border-gray-100">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 bg-primary/10 rounded-full flex items-center justify-center text-primary font-bold text-sm">{t.name.charAt(0)}</div>
              <span class="font-semibold text-sm text-text">{t.name}</span>
            </div>
            <span class="text-xs text-text-muted bg-bg-alt px-2 py-1 rounded-full">{t.service}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
