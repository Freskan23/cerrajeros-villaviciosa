---
interface Props { services: { name: string; slug: string }[]; }
const { services } = Astro.props;
---
<section class="section-alt">
  <div class="container">
    <h2 class="text-2xl font-bold text-center mb-8">Servicios relacionados</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-4xl mx-auto">
      {services.map(s => (
        <a href={`/servicios/${s.slug}`} class="bg-white p-5 rounded-xl shadow-sm card-hover text-center">
          <span class="text-text font-semibold">{s.name}</span>
          <span class="block text-primary text-sm mt-1">Ver más →</span>
        </a>
      ))}
    </div>
  </div>
</section>
