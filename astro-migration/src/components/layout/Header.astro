---
import { APP_BUSINESS_NAME, APP_PHONE_DISPLAY, APP_PHONE_HREF, APP_LOGO, SERVICES, ZONES } from '../../data/business';
---

<header class="glass-header fixed top-0 left-0 right-0 z-50">
  <div class="container flex items-center justify-between h-16 md:h-20">
    <a href="/" class="flex items-center gap-2 font-bold text-xl text-primary">
      <img src={APP_LOGO} alt={APP_BUSINESS_NAME} class="h-10 w-auto" loading="eager" width="40" height="40" />
      <span class="hidden sm:inline text-sm md:text-base font-bold leading-tight">Cerrajeros<br/>Villaviciosa 24h</span>
    </a>

    <nav class="hidden lg:flex items-center gap-1" aria-label="Navegación principal">
      <a href="/" class="px-3 py-2 text-sm font-medium text-text hover:text-primary transition-colors rounded-lg hover:bg-bg-alt">Inicio</a>

      <div class="relative group">
        <button class="px-3 py-2 text-sm font-medium text-text hover:text-primary transition-colors rounded-lg hover:bg-bg-alt flex items-center gap-1">
          Servicios
          <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-200">
          <div class="bg-white rounded-xl shadow-xl border border-border p-4 min-w-[280px]">
            {SERVICES.map(s => (
              <a href={`/servicios/${s.slug}`} class="flex items-center justify-between px-4 py-3 text-sm text-text-light hover:text-primary hover:bg-bg-alt rounded-lg transition-colors">
                <span>{s.name}</span>
                <span class="text-xs text-text-muted">{s.price}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <a href="/urgencias-24h" class="px-3 py-2 text-sm font-bold text-danger hover:text-danger-dark transition-colors rounded-lg hover:bg-red-50">🚨 Urgencias 24h</a>

      <div class="relative group">
        <button class="px-3 py-2 text-sm font-medium text-text hover:text-primary transition-colors rounded-lg hover:bg-bg-alt flex items-center gap-1">
          Zonas
          <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-200">
          <div class="bg-white rounded-xl shadow-xl border border-border p-4 min-w-[320px]">
            <p class="text-xs font-bold text-text-muted uppercase tracking-wider px-4 pb-2">Barrios de Villaviciosa</p>
            {ZONES.filter(z => z.type === 'barrio').map(z => (
              <a href={`/zonas/${z.slug}`} class="block px-4 py-2 text-sm text-text-light hover:text-primary hover:bg-bg-alt rounded-lg transition-colors">{z.name}</a>
            ))}
            <hr class="my-3 border-border" />
            <p class="text-xs font-bold text-text-muted uppercase tracking-wider px-4 pb-2">Municipios cercanos</p>
            {ZONES.filter(z => z.type === 'municipio').map(z => (
              <a href={`/zonas/${z.slug}`} class="block px-4 py-2 text-sm text-text-light hover:text-primary hover:bg-bg-alt rounded-lg transition-colors">{z.name}</a>
            ))}
          </div>
        </div>
      </div>

      <a href="/blog" class="px-3 py-2 text-sm font-medium text-text hover:text-primary transition-colors rounded-lg hover:bg-bg-alt">Blog</a>
      <a href="/contacto" class="px-3 py-2 text-sm font-medium text-text hover:text-primary transition-colors rounded-lg hover:bg-bg-alt">Contacto</a>
    </nav>

    <a href={APP_PHONE_HREF} class="hidden md:flex items-center gap-2 bg-danger hover:bg-danger-dark text-white px-4 py-2.5 rounded-xl font-bold text-sm transition-all shadow-md hover:shadow-lg">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
      {APP_PHONE_DISPLAY}
    </a>

    <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" aria-hidden="true" />
    <label for="mobile-menu-toggle" class="lg:hidden cursor-pointer p-2 rounded-lg hover:bg-bg-alt" aria-label="Abrir menú">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </label>

    <div class="hidden peer-checked:block fixed inset-0 top-16 bg-white z-40 lg:hidden overflow-y-auto">
      <nav class="container py-6 flex flex-col gap-2" aria-label="Menú móvil">
        <a href="/" class="px-4 py-3 text-lg font-medium text-text hover:bg-bg-alt rounded-lg">Inicio</a>
        <p class="px-4 pt-4 pb-1 text-xs font-bold text-text-muted uppercase tracking-wider">Servicios</p>
        {SERVICES.map(s => (
          <a href={`/servicios/${s.slug}`} class="px-6 py-2 text-sm text-text-light hover:text-primary hover:bg-bg-alt rounded-lg">{s.name}</a>
        ))}
        <a href="/urgencias-24h" class="px-4 py-3 text-lg font-bold text-danger">🚨 Urgencias 24h</a>
        <p class="px-4 pt-4 pb-1 text-xs font-bold text-text-muted uppercase tracking-wider">Zonas</p>
        {ZONES.filter(z => z.type === 'barrio').map(z => (
          <a href={`/zonas/${z.slug}`} class="px-6 py-2 text-sm text-text-light hover:text-primary hover:bg-bg-alt rounded-lg">{z.name}</a>
        ))}
        <a href="/blog" class="px-4 py-3 text-lg font-medium text-text hover:bg-bg-alt rounded-lg">Blog</a>
        <a href="/contacto" class="px-4 py-3 text-lg font-medium text-text hover:bg-bg-alt rounded-lg">Contacto</a>
        <a href={APP_PHONE_HREF} class="mx-4 mt-4 flex items-center justify-center gap-2 bg-danger text-white px-6 py-4 rounded-xl font-bold text-lg">
          📞 Llamar: {APP_PHONE_DISPLAY}
        </a>
      </nav>
    </div>
  </div>
</header>
<div class="h-16 md:h-20"></div>
