---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import { APP_PHONE_DISPLAY, APP_PHONE_HREF, APP_EMAIL, APP_FULL_ADDRESS, SITE_URL } from '../data/business';
---
<BaseLayout title="Contacto | Cerrajeros Villaviciosa 24h" description={`Contacta con Cerrajeros Villaviciosa 24h. Teléfono ${APP_PHONE_DISPLAY}. Disponibles 24 horas. Presupuesto sin compromiso.`} canonicalUrl={`${SITE_URL}/contacto`}>
  <Breadcrumbs items={[{ name: 'Contacto', url: '/contacto' }]} />
  <section class="py-16 md:py-24">
    <div class="container">
      <h1 class="text-4xl font-bold text-center mb-4">Contacto</h1>
      <p class="text-text-muted text-center mb-12 max-w-2xl mx-auto">Estamos disponibles 24 horas para atenderte. Llámanos o envíanos un mensaje.</p>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-5xl mx-auto">
        <div>
          <h2 class="text-2xl font-bold mb-6">Datos de contacto</h2>
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <div>
                <p class="font-bold text-text">Teléfono</p>
                <a href={APP_PHONE_HREF} class="text-primary font-bold text-lg hover:underline">{APP_PHONE_DISPLAY}</a>
                <p class="text-text-muted text-sm">Disponible 24h — Urgencias y WhatsApp</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
              </div>
              <div>
                <p class="font-bold text-text">Email</p>
                <a href={`mailto:${APP_EMAIL}`} class="text-primary hover:underline">{APP_EMAIL}</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
              </div>
              <div>
                <p class="font-bold text-text">Dirección</p>
                <p class="text-text-muted">{APP_FULL_ADDRESS}</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div>
                <p class="font-bold text-text">Horario</p>
                <p class="text-text-muted">24 horas, 365 días al año</p>
              </div>
            </div>
          </div>
        </div>

        <div>
          <h2 class="text-2xl font-bold mb-6">Envíanos un mensaje</h2>
          <form class="space-y-4" action="#" method="POST">
            <div>
              <label for="name" class="block text-sm font-medium text-text mb-1">Nombre</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 border border-border-light rounded-xl focus:ring-2 focus:ring-primary focus:border-transparent outline-none" placeholder="Tu nombre" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-text mb-1">Teléfono</label>
              <input type="tel" id="phone" name="phone" required class="w-full px-4 py-3 border border-border-light rounded-xl focus:ring-2 focus:ring-primary focus:border-transparent outline-none" placeholder="Tu teléfono" />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-text mb-1">Mensaje</label>
              <textarea id="message" name="message" rows="4" required class="w-full px-4 py-3 border border-border-light rounded-xl focus:ring-2 focus:ring-primary focus:border-transparent outline-none resize-none" placeholder="Describe tu problema o consulta..."></textarea>
            </div>
            <button type="submit" class="inline-flex items-center justify-center gap-3 bg-[#0a1628] text-white font-bold w-full px-8 py-4 rounded-xl hover:bg-primary transition-all">Enviar mensaje</button>
            <p class="text-xs text-text-muted text-center">Al enviar aceptas nuestra <a href="/politica-privacidad" class="underline">política de privacidad</a>.</p>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
