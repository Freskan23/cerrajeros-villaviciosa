---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import CTACallBanner from '../../components/sections/CTACallBanner.astro';

const posts = (await getCollection('blog')).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<BaseLayout title="Blog de Cerrajería | Cerrajeros Villaviciosa 24h" description="Consejos de seguridad, prevención de robos y novedades en cerrajería para Villaviciosa del Odón.">
  <Breadcrumbs items={[{ name: 'Blog', url: '/blog' }]} />
  <section class="section">
    <div class="container">
      <h1 class="text-4xl font-bold text-center mb-4">Blog de Cerrajería</h1>
      <p class="text-text-muted text-center mb-12 max-w-2xl mx-auto">Consejos de seguridad, prevención de robos y novedades en cerrajería para Villaviciosa del Odón</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
        {posts.map(post => (
          <a href={`/blog/${post.slug}`} class="bg-white rounded-2xl shadow-sm overflow-hidden card-hover block">
            <div class="h-48 overflow-hidden">
              <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <span class="bg-primary/10 text-primary px-3 py-1 rounded-full text-xs font-semibold">{post.data.category}</span>
                <time class="text-text-muted text-xs" datetime={post.data.date}>
                  {new Date(post.data.date).toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              </div>
              <h2 class="text-lg font-bold text-text mb-2 line-clamp-2">{post.data.title}</h2>
              <p class="text-text-muted text-sm line-clamp-3">{post.data.description}</p>
              <span class="inline-block mt-4 text-primary font-semibold text-sm">Leer más →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
  <CTACallBanner />
</BaseLayout>
