---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQSection from '../components/sections/FAQSection.astro';
import CTACallBanner from '../components/sections/CTACallBanner.astro';
import TestimonialsGrid from '../components/sections/TestimonialsGrid.astro';
import BrandsCarousel from '../components/sections/BrandsCarousel.astro';
import { testimonials } from '../data/testimonials';
import { SERVICES, ZONES, APP_PHONE_DISPLAY, APP_PHONE_HREF, APP_DESCRIPTION } from '../data/business';

const homeFaqs = [
  { question: '¿Cuánto cuesta un cerrajero en Villaviciosa del Odón?', answer: 'Desde 80€ dependiendo del servicio. Siempre damos precio cerrado por teléfono antes de acudir, sin sorpresas.' },
  { question: '¿Cuánto tardáis en llegar?', answer: '15-20 minutos de media a cualquier barrio de Villaviciosa del Odón: Centro, El Bosque, Campodón, Castillo, Monte de la Villa.' },
  { question: '¿Trabajáis festivos y fines de semana?', answer: 'Sí, nuestro servicio es 24 horas los 365 días del año, incluidos festivos y madrugadas.' },
  { question: '¿Emitís factura?', answer: 'Sí, factura completa con IVA válida para reclamaciones al seguro del hogar.' },
  { question: '¿Rompéis la cerradura al abrir?', answer: 'No. En el 95% de los casos la apertura es sin daños y la cerradura queda funcional.' },
  { question: '¿Qué marcas de cerraduras instaláis?', answer: 'Trabajamos con Tesa, Mottura, FAC, Yale, Keso, Ezcurra e Iseo. Todas con certificación antibumping y garantía.' },
];

const barrios = ZONES.filter(z => z.type === 'barrio');
const municipios = ZONES.filter(z => z.type === 'municipio');
---

<BaseLayout title="Cerrajeros Villaviciosa del Odón 24h | Urgencias 20 min" description={APP_DESCRIPTION}>

  <!-- ========== HERO ========== -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden bg-[#0a1628]">
    <img src="/hero-cerrajero.webp" alt="Cerrajero profesional en Villaviciosa del Odón" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-b from-[#0a1628]/70 via-[#0a1628]/50 to-[#0a1628]/95"></div>
    <div class="relative z-10 container text-white py-16 md:py-24">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm text-white/90 text-sm font-medium px-4 py-2 rounded-full mb-8 border border-white/10">
          <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
          Servicio activo 24h — Disponibles ahora
        </div>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-black mb-6 leading-[1.08] tracking-tight">
          Cerrajeros en<br/>Villaviciosa del Odón
        </h1>
        <p class="text-lg md:text-xl text-white/70 max-w-xl mb-10 leading-relaxed">
          Llegamos en 20 minutos. Apertura de puertas desde 90€. Precio cerrado por teléfono, sin sorpresas.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href={APP_PHONE_HREF} class="inline-flex items-center justify-center gap-3 bg-white text-[#0a1628] font-bold text-lg px-8 py-4 rounded-xl hover:bg-gray-100 transition-all shadow-lg shadow-white/10">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            {APP_PHONE_DISPLAY}
          </a>
          <a href="/urgencias-24h" class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/20 text-white font-semibold rounded-xl hover:bg-white/10 transition-all text-lg">
            Urgencias 24h
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
        <!-- Stats -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-px bg-white/10 rounded-2xl overflow-hidden">
          <div class="bg-[#0a1628]/80 backdrop-blur-sm px-5 py-4 text-center">
            <span class="block text-2xl md:text-3xl font-black text-white">20'</span>
            <span class="text-xs text-white/50 uppercase tracking-wider">Llegada</span>
          </div>
          <div class="bg-[#0a1628]/80 backdrop-blur-sm px-5 py-4 text-center">
            <span class="block text-2xl md:text-3xl font-black text-white">90€</span>
            <span class="text-xs text-white/50 uppercase tracking-wider">Desde</span>
          </div>
          <div class="bg-[#0a1628]/80 backdrop-blur-sm px-5 py-4 text-center">
            <span class="block text-2xl md:text-3xl font-black text-white">24/7</span>
            <span class="text-xs text-white/50 uppercase tracking-wider">Horario</span>
          </div>
          <div class="bg-[#0a1628]/80 backdrop-blur-sm px-5 py-4 text-center">
            <span class="block text-2xl md:text-3xl font-black text-white">4.9</span>
            <span class="text-xs text-white/50 uppercase tracking-wider">Valoración</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== SERVICIOS ========== -->
  <section class="py-20 md:py-28 bg-white">
    <div class="container">
      <div class="max-w-2xl mb-14">
        <p class="text-sm font-semibold text-primary uppercase tracking-widest mb-3">Servicios</p>
        <h2 class="text-3xl md:text-4xl font-black text-text mb-4 leading-tight">Soluciones profesionales de cerrajería</h2>
        <p class="text-text-muted">Para hogares, comercios y comunidades en Villaviciosa del Odón y alrededores.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SERVICES.map(s => (
          <a href={`/servicios/${s.slug}`} class="group flex items-center gap-4 p-5 rounded-2xl border border-gray-100 hover:border-primary/20 hover:bg-primary/[0.02] transition-all duration-200">
            <div class="flex-shrink-0 w-12 h-12 bg-gray-50 group-hover:bg-primary/10 rounded-xl flex items-center justify-center transition-colors">
              <svg class="w-5 h-5 text-gray-400 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between">
                <h3 class="font-semibold text-text group-hover:text-primary transition-colors">{s.name}</h3>
                <svg class="w-4 h-4 text-gray-300 group-hover:text-primary group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              </div>
              <span class="text-sm text-danger font-semibold">{s.price}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== POR QUÉ ELEGIRNOS ========== -->
  <section class="py-20 md:py-28 bg-gray-50">
    <div class="container">
      <div class="max-w-2xl mb-14">
        <p class="text-sm font-semibold text-primary uppercase tracking-widest mb-3">Ventajas</p>
        <h2 class="text-3xl md:text-4xl font-black text-text mb-4 leading-tight">Por qué confiar en nosotros</h2>
        <p class="text-text-muted">Más de 20 años como cerrajeros de referencia en Villaviciosa del Odón.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>', title: 'Llegamos en 20 minutos', desc: 'Unidades móviles distribuidas en Villaviciosa del Odón para respuesta inmediata.' },
          { icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/></svg>', title: 'Precio cerrado', desc: 'Te damos el precio exacto por teléfono antes de acudir. Sin sorpresas ni recargos.' },
          { icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>', title: 'Sin romper nada', desc: 'Técnicas de apertura no destructiva en el 95% de los casos.' },
          { icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>', title: 'Factura para seguro', desc: 'Documentación completa y válida para reclamaciones a tu aseguradora.' },
          { icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>', title: '+20 años de experiencia', desc: 'Empresa local con décadas protegiendo hogares en la zona oeste de Madrid.' },
          { icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>', title: 'Garantía por escrito', desc: 'Todos nuestros trabajos tienen garantía documentada. Tu seguridad es prioridad.' },
        ].map(item => (
          <div class="bg-white rounded-2xl p-7 border border-gray-100 hover:border-gray-200 hover:shadow-sm transition-all">
            <div class="w-11 h-11 bg-primary/10 rounded-xl flex items-center justify-center text-primary mb-5" set:html={item.icon} />
            <h3 class="text-lg font-bold text-text mb-2">{item.title}</h3>
            <p class="text-sm text-text-muted leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== ZONAS ========== -->
  <section class="py-20 md:py-28 bg-white">
    <div class="container">
      <div class="max-w-2xl mb-14">
        <p class="text-sm font-semibold text-primary uppercase tracking-widest mb-3">Cobertura</p>
        <h2 class="text-3xl md:text-4xl font-black text-text mb-4 leading-tight">Zonas de servicio</h2>
        <p class="text-text-muted">Cobertura completa en Villaviciosa del Odón y municipios de la zona oeste de Madrid.</p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 max-w-5xl">
        <div>
          <h3 class="text-sm font-semibold text-text uppercase tracking-widest mb-4">Barrios de Villaviciosa del Odón</h3>
          <div class="grid grid-cols-2 gap-2">
            {barrios.map(z => (
              <a href={`/zonas/${z.slug}`} class="flex items-center gap-2 px-4 py-3 rounded-xl text-sm font-medium text-text hover:text-primary hover:bg-primary/5 transition-all border border-transparent hover:border-primary/10">
                <svg class="w-4 h-4 text-primary/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
                {z.name}
              </a>
            ))}
          </div>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-text uppercase tracking-widest mb-4">Municipios cercanos</h3>
          <div class="grid grid-cols-2 gap-2">
            {municipios.map(z => (
              <a href={`/zonas/${z.slug}`} class="flex items-center gap-2 px-4 py-3 rounded-xl text-sm font-medium text-text-muted hover:text-primary hover:bg-primary/5 transition-all border border-transparent hover:border-primary/10">
                <svg class="w-4 h-4 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
                {z.name}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TESTIMONIOS ========== -->
  <TestimonialsGrid testimonials={testimonials} limit={6} />

  <!-- ========== FAQ ========== -->
  <FAQSection faqs={homeFaqs} title="Preguntas frecuentes" />

  <!-- ========== MARCAS ========== -->
  <BrandsCarousel />

  <!-- ========== CTA ========== -->
  <CTACallBanner />

</BaseLayout>
